# Copy this file to .env and update CLIENT_ORIGIN/PORT if needed.
CLIENT_ORIGIN=http://localhost:5173
PORT=4000

# Optional: override path to account name mapping
# ACCOUNT_NAMES_FILE=../account-names.json

# Optional: enable verbose Questrade API response logging
# DEBUG_QUESTRADE_API=false

# Token refresh lifecycle logging (JSONL) is enabled by default.
# Disable only if needed:
# DEBUG_QUESTRADE_TOKEN_FLOW=false
# Per-login refresh single-flight guard (prevents concurrent refresh races)
# ENABLE_QUESTRADE_REFRESH_SINGLE_FLIGHT=true
# Optional verbosity/size controls:
# DEBUG_QUESTRADE_TOKEN_FLOW_VERBOSE=false
# DEBUG_QUESTRADE_TOKEN_FLOW_STDOUT=false
# QUESTRADE_TOKEN_DEBUG_LOG_MAX_BYTES=10485760

# Optional: enable SnapTrade-backed logins such as Wealthsimple
# SNAPTRADE_CLIENT_ID=your-client-id
# SNAPTRADE_CONSUMER_KEY=your-consumer-key
# Individual SnapTrade logins may also store their own Client ID / Consumer Key.
# SNAPTRADE_DEFAULT_BROKER=WEALTHSIMPLETRADE
# SNAPTRADE_BASE_URL=https://api.snaptrade.com

# Enable verbose Yahoo Finance PEG ratio debugging output
DEBUG_YAHOO_PEG=true

# Optional: enable portfolio news powered by OpenAI GPT models
# OPENAI_API_KEY=sk-...
# OPENAI_NEWS_MODEL=gpt-5.0
